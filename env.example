import { useState } from "react";
import { motion, AnimatePresence } from "motion/react";
import { Heart, Calendar, Lock, Gem, Sparkles, AlertCircle, Info, ChevronRight } from "lucide-react";
import { calculateCompatibility } from "../utils/numerologyCalculator";

interface CompatibilityCalculatorProps {
  crystals: number;
  unlockedFeatures: string[];
  onUnlockFeature: (id: string, cost: number) => boolean;
  onSaveAction?: (type: "coin" | "compatibility", title: string, details: string) => void;
}

export default function CompatibilityCalculator({
  crystals,
  unlockedFeatures,
  onUnlockFeature,
  onSaveAction,
}: CompatibilityCalculatorProps) {
  const [date1, setDate1] = useState("1995-06-14");
  const [date2, setDate2] = useState("1997-09-08");
  const [name1, setName1] = useState("Я");
  const [name2, setName2] = useState("Партнер");

  const [compatResult, setCompatResult] = useState<any | null>(null);

  const [isCalculating, setIsCalculating] = useState(false);
  const [loadingTextIndex, setLoadingTextIndex] = useState(0);

  const loadingSteps = [
    "Переплетення кармічних ниток...",
    "Аналіз планетарних сумісностей...",
    "Синхронізація енергетичних тригонів...",
    "Визначення любовного резонансу..."
  ];

  const handleCalculate = () => {
    if (!date1 || !date2) return;
    setIsCalculating(true);
    setLoadingTextIndex(0);

    const interval = setInterval(() => {
      setLoadingTextIndex((prev) => (prev < loadingSteps.length - 1 ? prev + 1 : prev));
    }, 280);

    // Smooth scroll down to the loader/results anchor
    setTimeout(() => {
      document.getElementById("compat-results-anchor")?.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    }, 50);

    setTimeout(() => {
      try {
        const res = calculateCompatibility(date1, date2);
        setCompatResult(res);
        if (onSaveAction) {
          onSaveAction(
            "compatibility",
            `Сумісність: ${name1.trim() || "Особа 1"} + ${name2.trim() || "Особа 2"}`,
            `Резонанс ${res.score}% ✧ ${res.verdict.slice(0, 100)}...`
          );
        }
      } catch (err) {
        console.error(err);
      } finally {
        setIsCalculating(false);
        clearInterval(interval);
      }
    }, 1100);
  };

  // Generate unique feature ID for this specific couple calculation
  const getFeatureId = () => {
    const sortedDates = [date1, date2].sort().join("_");
    return `compatibility_${sortedDates}`;
  };

  const isUnlocked = () => {
    const id = getFeatureId();
    return unlockedFeatures.includes(id);
  };

  const handleUnlockFeedback = () => {
    const id = getFeatureId();
    onUnlockFeature(id, 25);
  };

  return (
    <div id="compatibility-main-container" className="max-w-4xl mx-auto space-y-6">
      <div className="p-6 sm:p-8 rounded-3xl glass border-white/5 shadow-xl">
        <h2 className="font-display text-lg font-light text-white mb-3 uppercase tracking-[0.2em] flex items-center gap-2">
          <Heart className="w-5 h-5 text-purple-400 animate-pulse" />
          <span>Кабалістична Сумісність</span>
        </h2>
        <p className="text-xs text-white/50 mb-6 leading-relaxed font-light">
          Введіть дати народження обох людей, щоб виміряти резонанс між вашими енергетичними лініями, шляхами долі та темпераментом у матриці.
        </p>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          {/* Person 1 Input */}
          <div className="p-4 rounded-2xl bg-white/[0.02] border border-white/5">
            <h3 className="text-[10px] font-semibold text-purple-300 mb-3 tracking-[0.25em] uppercase">Особа 1</h3>
            <div className="space-y-3 font-display">
              <input
                type="text"
                id="compat-name-1"
                placeholder="Ім'я (напр. Ви)"
                value={name1}
                onChange={(e) => setName1(e.target.value)}
                className="w-full bg-white/5 border border-white/10 rounded-xl p-2.5 text-xs text-[#e2e2e7] placeholder-white/20"
              />
              <div className="relative">
                <Calendar className="absolute left-3 top-3 w-4 h-4 text-purple-400/40" />
                <input
                  type="date"
                  id="compat-date-1"
                  value={date1}
                  onChange={(e) => setDate1(e.target.value)}
                  className="w-full bg-white/5 border border-white/10 rounded-xl p-2.5 pl-10 text-xs text-white cursor-pointer"
                />
              </div>
            </div>
          </div>

          {/* Person 2 Input */}
          <div className="p-4 rounded-2xl bg-white/[0.02] border border-white/5">
            <h3 className="text-[10px] font-semibold text-purple-300 mb-3 tracking-[0.25em] uppercase">Особа 2</h3>
            <div className="space-y-3 font-display">
              <input
                type="text"
                id="compat-name-2"
                placeholder="Ім'я партнера"
                value={name2}
                onChange={(e) => setName2(e.target.value)}
                className="w-full bg-white/5 border border-white/10 rounded-xl p-2.5 text-xs text-[#e2e2e7] placeholder-white/20"
              />
              <div className="relative">
                <Calendar className="absolute left-3 top-3 w-4 h-4 text-purple-400/40" />
                <input
                  type="date"
                  id="compat-date-2"
                  value={date2}
                  onChange={(e) => setDate2(e.target.value)}
                  className="w-full bg-white/5 border border-white/10 rounded-xl p-2.5 pl-10 text-xs text-white cursor-pointer"
                />
              </div>
            </div>
          </div>
        </div>

        <button
          id="compat-calc-btn"
          onClick={handleCalculate}
          className="w-full py-4 rounded-xl bg-purple-500/20 border border-purple-500/40 hover:bg-purple-500/30 font-display text-xs tracking-[0.2em] uppercase text-purple-200 cursor-pointer select-none transition-all"
        >
          Обчислити Резонанс Долі
        </button>
      </div>

      {/* Results Anchor */}
      <div id="compat-results-anchor" className="scroll-mt-6" />

      {/* Results Rendering */}
      <AnimatePresence mode="wait">
        {isCalculating ? (
          <motion.div
            key="compat-loader"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="p-8 sm:p-12 rounded-3xl glass border-white/5 flex flex-col items-center justify-center text-center relative overflow-hidden min-h-[350px] shadow-xl"
          >
            {/* Pulsing hearts / rings logic */}
            <div className="relative w-36 h-36 mb-6 flex items-center justify-center">
              <motion.div
                animate={{ scale: [1, 1.2, 1], opacity: [0.3, 0.7, 0.3] }}
                transition={{ repeat: Infinity, duration: 2, ease: "easeInOut" }}
                className="absolute inset-0 rounded-full border border-purple-500/20"
              />
              <motion.div
                animate={{ scale: [1.2, 1, 1.2], opacity: [0.2, 0.5, 0.2] }}
                transition={{ repeat: Infinity, duration: 2, ease: "easeInOut" }}
                className="absolute inset-3 rounded-full border border-indigo-400/20"
              />
              {/* Spinning star */}
              <motion.div
                animate={{ rotate: 360 }}
                transition={{ repeat: Infinity, duration: 6, ease: "linear" }}
                className="absolute inset-6 rounded-full border border-dashed border-purple-400/30"
              />
              {/* Couple visual - Two small overlapping glowing crystals */}
              <div className="flex gap-2 relative z-10">
                <motion.div
                  animate={{ y: [-3, 3, -3] }}
                  transition={{ repeat: Infinity, duration: 1.5, ease: "easeInOut" }}
                  className="crystal-shape crystal-glow scale-90"
                />
                <motion.div
                  animate={{ y: [3, -3, 3] }}
                  transition={{ repeat: Infinity, duration: 1.5, ease: "easeInOut" }}
                  className="crystal-shape crystal-glow scale-90"
                  style={{ filter: "hue-rotate(60deg)" }}
                />
              </div>
            </div>

            <h3 className="font-display text-lg font-light tracking-widest text-[#e2e2e7] uppercase mb-2">
              Аналіз Сумісності
            </h3>
            <div className="h-6 overflow-hidden">
              <AnimatePresence mode="popLayout">
                <motion.p
                  key={loadingTextIndex}
                  initial={{ opacity: 0, y: 10 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -10 }}
                  className="text-xs text-purple-300 font-mono tracking-widest"
                >
                  {loadingSteps[loadingTextIndex]}
                </motion.p>
              </AnimatePresence>
            </div>

            <div className="w-48 h-1 bg-white/5 rounded-full mt-5 overflow-hidden relative">
              <motion.div
                initial={{ width: "0%" }}
                animate={{ width: "100%" }}
                transition={{ duration: 1.1, ease: "easeInOut" }}
                className="h-full bg-gradient-to-r from-purple-500 to-indigo-400 rounded-full"
              />
            </div>
          </motion.div>
        ) : compatResult && (
          <motion.div
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.95 }}
            className="space-y-6"
          >
            {/* Visual Ring and basic Score Header */}
            <div className="p-6 sm:p-8 rounded-3xl glass border-white/5 flex flex-col md:flex-row items-center justify-around gap-6">
              {/* Progress Circle Visual */}
              <div className="relative flex items-center justify-center w-36 h-36 shrink-0 select-none">
                <svg className="w-full h-full transform -rotate-90">
                  {/* Background Circle */}
                  <circle
                    cx="72"
                    cy="72"
                    r="62"
                    className="stroke-white/5 stroke-[5] fill-none"
                  />
                  {/* Matching Arc */}
                  <motion.circle
                    cx="72"
                    cy="72"
                    r="62"
                    className="stroke-purple-400 stroke-[6] fill-none"
                    strokeDasharray="390"
                    initial={{ strokeDashoffset: 390 }}
                    animate={{ strokeDashoffset: 390 - (390 * compatResult.score) / 100 }}
                    transition={{ duration: 1.2, ease: "easeOut" }}
                    strokeLinecap="round"
                  />
                </svg>
                {/* Score value centered */}
                <div className="absolute text-center">
                  <span className="text-3xl font-extrabold font-mono text-white tracking-tighter">
                    {compatResult.score}%
                  </span>
                  <p className="text-[9px] text-purple-400 font-mono uppercase tracking-[0.2em] leading-none mt-1.5">Резонанс</p>
                </div>
              </div>

              {/* Summary and Overview */}
              <div className="flex-1 text-center md:text-left space-y-3">
                <span className="text-[10px] font-mono tracking-widest text-purple-300 bg-white/5 border border-white/10 px-2.5 py-1 rounded-lg">
                  Сумісність {name1} та {name2}
                </span>
                <h3 className="font-display text-xl font-light text-white leading-tight">
                  Як ваші космічні коди взаємодіють?
                </h3>
                <p className="text-xs text-white/40 font-mono tracking-wider">
                  Дата 1: {date1.split("-").reverse().join(".")} ✧ Дата 2: {date2.split("-").reverse().join(".")}
                </p>
                <div className="text-xs sm:text-sm text-white/70 leading-relaxed bg-white/[0.02] p-4 rounded-2xl border border-white/5 md:max-w-lg font-display">
                  Загальна оцінка сумісності становить <span className="text-purple-300 font-bold font-mono">{compatResult.score}%</span>. Це показує ступінь початкової гармонії вібрацій між вашими психоматрицями.
                </div>
              </div>
            </div>

            {/* Locked vs. Unlocked Deep Dive Section */}
            {!isUnlocked() ? (
              <div id="locked-compat-box" className="p-8 sm:p-12 rounded-3xl glass border-white/5 text-center space-y-5 relative overflow-hidden">
                <div className="w-14 h-14 rounded-full glass border-white/10 flex items-center justify-center text-amber-400 mx-auto">
                  <Lock className="w-6 h-6" />
                </div>

                <div className="space-y-1.5Packed">
                  <h3 className="font-display text-lg font-light text-amber-200 uppercase tracking-widest">Кармічний Звіт Герметизовано</h3>
                  <p className="text-xs sm:text-sm text-white/50 max-w-lg mx-auto leading-relaxed font-light font-display">
                    Для перегляду детального аналізу сумісності (вердикту душ, життєвих ліній, темпераменту та ставлення до грошей) необхідно використати силу Кристалів Долі.
                  </p>
                </div>

                <div className="max-w-md mx-auto p-4 rounded-2xl bg-white/[0.02] border border-white/5 divide-y divide-white/5 text-left text-xs text-white/60 mb-2 font-display">
                  <div className="py-2.5 flex items-center gap-2.5"><ChevronRight className="w-3.5 h-3.5 text-purple-400" /> Спільні життєві стежки (Число Життєвого Шляху)</div>
                  <div className="py-2.5 flex items-center gap-2.5"><ChevronRight className="w-3.5 h-3.5 text-purple-400" /> Попарний аналіз емоційного та сексуального темпераменту</div>
                  <div className="py-2.5 flex items-center gap-2.5"><ChevronRight className="w-3.5 h-3.5 text-purple-400" /> Фінансові відносини та побутовий рівень порозуміння</div>
                </div>

                <motion.button
                  id="unlock-compatibility-btn"
                  whileHover={{ scale: 1.03 }}
                  whileTap={{ scale: 0.97 }}
                  onClick={handleUnlockFeedback}
                  className="px-6 py-3 rounded-xl bg-purple-500/20 border border-purple-500/40 hover:bg-purple-500/30 text-purple-100 font-semibold text-[10px] tracking-widest uppercase flex items-center gap-2.5 mx-auto cursor-pointer transition-all"
                >
                  <div className="crystal-shape scale-75" />
                  <span>Розблокувати Звіт за 25 💎</span>
                </motion.button>
              </div>
            ) : (
              <motion.div
                id="unlocked-compat-report"
                initial={{ opacity: 0, y: 15 }}
                animate={{ opacity: 1, y: 0 }}
                className="space-y-4"
              >
                {/* 1. Unlocked Verdict banner */}
                <div className="p-6 rounded-3xl glass border-white/5">
                  <h4 className="text-[10px] uppercase tracking-[0.2em] text-amber-300 font-mono flex items-center gap-2 mb-2">
                    <Sparkles className="w-4 h-4 text-amber-400 animate-pulse" />
                    <span>Кармічний Вердикт</span>
                  </h4>
                  <p className="font-display italic text-base sm:text-lg text-white/90 leading-relaxed font-light">
                    &ldquo;{compatResult.verdict}&rdquo;
                  </p>
                </div>

                {/* 2. Detailed analytics points */}
                <div className="grid grid-cols-1 gap-4">
                  {compatResult.points.map((pt: any, i: number) => {
                    let statusColor = "border-white/5 bg-white/[0.01]";
                    let textColor = "text-purple-300";
                    let badge = "Невідомо";
                    if (pt.status === "good") {
                      statusColor = "border-emerald-500/20 bg-emerald-500/5";
                      textColor = "text-emerald-400";
                      badge = "Гармонія ✧";
                    } else if (pt.status === "bad") {
                      statusColor = "border-red-500/20 bg-red-500/5";
                      textColor = "text-red-400";
                      badge = "Виклик ⚔";
                    } else {
                      statusColor = "border-white/5 bg-white/[0.02]";
                      textColor = "text-purple-300";
                      badge = "Нейтрально ⚖";
                    }

                    return (
                      <div key={i} className={`p-5 rounded-2xl border ${statusColor} space-y-2`}>
                        <div className="flex items-center justify-between">
                          <h5 className="font-display text-sm font-normal text-white">{pt.title}</h5>
                          <span className={`text-[9px] font-mono uppercase bg-black/30 px-2 py-0.5 rounded border border-white/5 ${textColor}`}>
                            {badge}
                          </span>
                        </div>
                        <p className="text-xs text-white/70 leading-relaxed font-light font-display">
                          {pt.text}
                        </p>
                      </div>
                    );
                  })}
                </div>

                {/* Advice footer info */}
                <div className="p-4 rounded-xl bg-white/[0.01] border border-white/5 flex items-start gap-2.5 text-[10px] text-white/40 font-display">
                  <Info className="w-4 h-4 opacity-40 shrink-0 mt-0.5" />
                  <p className="leading-relaxed">
                    * Нумерологічна сумісність лише окреслює схильності, вібраційні тригони та можливі зони тертя у спільному полі. Будь-які виклики у стосунках успішно вирішуються свідомим діалогом, увагою та підтримкою одне одного.
                  </p>
                </div>
              </motion.div>
            )}
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
